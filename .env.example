# =============================================================================
# RSC Gateway — environment template (SAFE TO COMMIT)
# =============================================================================
#
#   cp .env.example .env
#
#   .env  → local secrets only — NEVER push to GitHub
#   Prod  → K8s Secrets / DigitalOcean encrypted env / Vault
#
# Architecture (env loaded once at boot in cmd/main.rs → Config → AppState):
#
#   Frontend Apps
#         ↓
#   routes/          (HTTP only — no env::var, no secrets)
#         ↓
#   internal/        (services, handlers, workers)
#         ↓
#   Database | Redis | Blockchain | Providers (Striga, Transak, swaps)
#
# Only internal/config/* reads environment variables.
# =============================================================================

ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS — inject via .env locally; use secret manager in production
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (required)
DATABASE_URL=postgres://gateway:gateway@localhost:5432/gateway

# Redis sessions, rate limits, queues (required)
REDIS_URL=redis://127.0.0.1:6379

# JWT signing — min 32 chars in production (required)
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_SECRET_PREVIOUS=
JWT_KID_CURRENT=v1
JWT_KID_PREVIOUS=

# MFA encryption at rest — min 32 chars in production (defaults to JWT_SECRET if empty)
MFA_ENCRYPTION_KEY=

# Transak crypto on-ramp / off-ramp (optional when FIAT_MOCK_MODE=true)
TRANSAK_API_KEY=
TRANSAK_SECRET=
TRANSAK_ENVIRONMENT=staging
TRANSAK_WEBHOOK_SECRET=

# Striga banking (RSC Bank cards, KYC, IBAN) — sandbox by default
STRIGA_APP_ID=
STRIGA_API_KEY=
STRIGA_API_SECRET=
STRIGA_UI_SECRET=
STRIGA_BASE_URL=https://www.sandbox.striga.com/api/v1
STRIGA_WEBHOOK_SECRET=
STRIGA_MOCK_MODE=true

# Swap liquidity providers
# SWAP_PROVIDER_LIQUIDITY_DEX_API_KEY=
# SWAP_PROVIDER_LIQUIDITY_CEX_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Server & observability (non-secret defaults)
# ─────────────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8080
RUST_LOG=rsc_gateway=debug,tower_http=debug

DB_MAX_CONNECTIONS=10

JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7
MFA_CHALLENGE_MINUTES=5
MFA_ISSUER=RSC Gateway

AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECS=900
AUTH_MAX_SESSIONS_PER_USER=10
TRUSTED_PROXIES=127.0.0.1

ALLOWED_ORIGINS=*
REQUEST_TIMEOUT_SECS=30
RATE_LIMIT_PER_SECOND=100

# Blockchain (RSC node / indexer)
RSC_RPC_URL=http://127.0.0.1:8545
RSC_WS_URL=ws://127.0.0.1:8546
RSC_CHAIN_ID=
RSC_RPC_TIMEOUT_SECS=30
DEPOSIT_MIN_CONFIRMATIONS=12
DEPOSIT_WORKER_ENABLED=true

# Transak / fiat (non-secret URLs / flags)
TRANSAK_API_BASE_URL=
TRANSAK_MOCK_MODE=
FIAT_MOCK_MODE=true

# Swaps
SWAP_PROVIDERS=liquidity-dex@DEX,liquidity-cex@CEX
SWAP_MOCK_MODE=true
SWAP_PLATFORM_FEE_BPS=25
SWAP_DEFAULT_SLIPPAGE_BPS=50

# Feature flags
FEATURE_FIAT_ON_RAMP=true
FEATURE_SWAPS=true
FEATURE_FRAUD_DETECTION=true
FEATURE_MAINTENANCE_MODE=false
FEATURE_MFA_REQUIRED=false

# Observability
METRICS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rsc-gateway
OTEL_TRACES_SAMPLE_RATIO=1.0
HEALTH_CHECK_BLOCKCHAIN=true

# Workers
WORKER_RETRY_MAX_ATTEMPTS=5
WORKER_RETRY_BASE_MS=1000
WORKER_RETRY_MAX_MS=300000
WORKER_QUEUE_POLL_INTERVAL_SECS=5
WORKER_WITHDRAWAL_POLL_INTERVAL_SECS=15
WORKER_WITHDRAWAL_ENABLED=true
WORKER_DLQ_AUDIT=true

# Threat intelligence
THREAT_INTEL_ENABLED=true
THREAT_INTEL_TOR_ENABLED=true
THREAT_INTEL_TOR_FEED_URL=https://check.torproject.org/torbulkexitlist
THREAT_INTEL_DATACENTER_ENABLED=true
THREAT_INTEL_DATACENTER_FEED_URL=https://raw.githubusercontent.com/firehol/blocklist-ipsets/master/datacenter.netset
THREAT_INTEL_REFRESH_INTERVAL_SECS=3600
THREAT_INTEL_HTTP_TIMEOUT_SECS=60
