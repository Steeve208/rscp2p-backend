# RSC P2P Backend - Variables de entorno
# Copiar a .env y ajustar valores. En producción NUNCA use JWT_SECRET por defecto.

# Entorno (development | production). En production se exige JWT_SECRET seguro.
ENVIRONMENT=development

# Servidor
HOST=0.0.0.0
PORT=8000

# CORS (orígenes del navegador: tu web Next, no la URL del API). Separados por coma.
# En desarrollo puede usar * (no permitido si ENVIRONMENT=production).
CORS_ORIGINS=*
# Producción (ejemplo p2prsc): liste cada origen exacto (esquema + host, sin path).
# CORS_ORIGINS=https://p2prsc.xyz,https://www.p2prsc.xyz
# Si el front es solo HTTP en el mismo proyecto:
# CORS_ORIGINS=http://p2prsc.xyz,http://www.p2prsc.xyz

# JWT (auth Face ID: challenge/verify + JWT). OBLIGATORIO en producción: genere un secret seguro.
JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_ACCESS_EXPIRE_MINUTES=60
# JWT_REFRESH_EXPIRE_DAYS=7

# Base de datos. SQLite SOLO para desarrollo local; producción REQUIERE PostgreSQL.
# Desarrollo:
# DATABASE_URL=sqlite:///./launchpad.db
# Producción (obligatorio):
DATABASE_URL=postgresql://user:pass@localhost:5432/rsc_p2p

# Rate limiting
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_MAX_REQUESTS=120
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Seguridad
# STRICT_SECURITY_HEADERS=true

# Redis (requerido para escala horizontal: rate limiting, Socket.IO adapter, cache)
REDIS_URL=redis://localhost:6379/0

# Webhook (blockchain watcher → POST /api/deposits)
# WEBHOOK_SECRET=generate-a-secure-random-secret

# Verificación on-chain (RPC del nodo blockchain)
# RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# CHAIN_ID=1
# MIN_CONFIRMATIONS=12
